<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <!-- ══════════════════════════════════════
         TOP BAR  (paddingTop set in code via WindowInsets)
         ══════════════════════════════════════ -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="20dp"
        android:paddingTop="12dp"
        android:paddingRight="12dp"
        android:paddingBottom="8dp"
        android:background="@color/bg_dark">

        <TextView
            android:id="@+id/heading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:fontFamily="sans-serif-medium"
            android:text="All Songs"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/search_button"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/search_icon" />

        <Button
            android:id="@+id/playlist_button"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_centerVertical="true"
            android:layout_marginEnd="10dp"
            android:layout_toStartOf="@id/search_button"
            android:background="@drawable/playlist" />

    </RelativeLayout>

    <!-- Thin divider under top bar -->
    <View
        android:id="@+id/topDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/topBar"
        android:background="@color/divider" />

    <!-- ══════════════════════════════════════
         SEARCH BAR  (card + inner SearchView)
         ══════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/searchCard"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_below="@id/topDivider"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="28dp"
        app:cardElevation="4dp">

        <SearchView
            android:id="@+id/searchView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:iconifiedByDefault="false"
            android:queryHint="Search audio file" />

    </androidx.cardview.widget.CardView>

    <!-- ══════════════════════════════════════
         SONG LIST  (playlist mode)
         ══════════════════════════════════════ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/controlPanel"
        android:layout_below="@id/searchCard"
        android:clipToPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        android:scrollbars="none" />

    <!-- ══════════════════════════════════════
         NOW PLAYING – album art card
         ══════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/Playing_Song_Cardview"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_below="@id/topDivider"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:visibility="gone"
        app:cardCornerRadius="20dp"
        app:cardElevation="20dp">

        <ImageView
            android:id="@+id/Playing_Song_Imageview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background" />

    </androidx.cardview.widget.CardView>

    <!-- ══════════════════════════════════════
         NOW PLAYING – visualizer
         ══════════════════════════════════════ -->
    <com.skd.pocketwaves.CustomVisualizerView
        android:id="@+id/visualizerView"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_above="@id/controlPanel"
        android:layout_below="@id/Playing_Song_Cardview"
        android:layout_centerHorizontal="true"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="12dp"
        android:layout_marginRight="8dp"
        android:layout_marginBottom="4dp"
        android:background="@color/bg_dark"
        android:visibility="gone" />

    <!-- ══════════════════════════════════════
         CONTROL PANEL  (always at bottom;
         paddingBottom set in code via WindowInsets)
         ══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/surface"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingTop="14dp"
        android:paddingRight="20dp"
        android:paddingBottom="20dp"
        android:visibility="gone">

        <!-- Song title -->
        <TextView
            android:id="@+id/song_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="marquee"
            android:fontFamily="@font/inter_500"
            android:marqueeRepeatLimit="marquee_forever"
            android:scrollHorizontally="true"
            android:singleLine="true"
            android:text="Song Title Here"
            android:textAlignment="center"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <!-- Artist name -->
        <TextView
            android:id="@+id/song_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:layout_marginBottom="12dp"
            android:ellipsize="end"
            android:singleLine="true"
            android:fontFamily="@font/inter_400"
            android:text="Artist Name"
            android:textStyle="bold"
            android:textAlignment="center"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <!-- Seek bar row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/positive_playback_timer"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="11sp" />

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progressBackgroundTint="@color/black"
                android:progressTint="@color/accent"
                android:thumbTint="@color/accent" />

            <TextView
                android:id="@+id/negative_playback_timer"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="-00:00"
                android:textStyle="bold"
                android:textAlignment="textEnd"
                android:textColor="@color/black"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Playback controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_horizontal"
            android:orientation="horizontal">

            <!-- Repeat -->
            <Button
                android:id="@+id/reapet_button"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="18dp"
                android:background="@drawable/repeat" />

            <!-- Previous -->
            <Button
                android:id="@+id/previousButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="14dp"
                android:background="@drawable/previous" />

            <!-- Play / Pause  (slightly larger) -->
            <Button
                android:id="@+id/pauseResumeButton"
                android:layout_width="62dp"
                android:layout_height="62dp"
                android:background="@drawable/play" />

            <!-- Next -->
            <Button
                android:id="@+id/nextButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="14dp"
                android:background="@drawable/next" />

            <!-- Shuffle -->
            <Button
                android:id="@+id/shuffleButton"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="18dp"
                android:background="@drawable/shuffle_off" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
