<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_bg"
    android:fitsSystemWindows="true">

    <!-- ══════════════════════════════════════
         CENTER — Logo + App Name + Tagline
         ══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/splashCenter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Glow ring behind logo -->
        <FrameLayout
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center">

            <!-- Outer glow circle -->
            <View
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center"
                android:alpha="0.18"
                android:background="@drawable/splash_logo_glow" />

            <!-- Inner glow circle -->
            <View
                android:layout_width="144dp"
                android:layout_height="144dp"
                android:layout_gravity="center"
                android:alpha="0.28"
                android:background="@drawable/splash_logo_glow" />

            <!-- Logo card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/splashLogoCard"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                app:cardBackgroundColor="#1E1760"
                app:cardCornerRadius="32dp"
                app:cardElevation="28dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/app_logo" />

            </androidx.cardview.widget.CardView>

        </FrameLayout>

        <!-- App name -->
        <TextView
            android:id="@+id/splashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.04"
            android:text="Pocket Waves"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold" />

        <!-- Tagline -->
        <TextView
            android:id="@+id/splashTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:letterSpacing="0.06"
            android:text="Feel Every Beat, Anywhere"
            android:textColor="#9B94FF"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- ══════════════════════════════════════
         BOTTOM — Animated equalizer + labels
         Anchored to parent bottom so it sits
         in the same place on every screen size
         ══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/splashBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="48dp"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Equalizer bars row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/bar1"
                android:layout_width="5dp"
                android:layout_height="14dp"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp"
                android:background="@drawable/wave_bar" />

            <View
                android:id="@+id/bar2"
                android:layout_width="5dp"
                android:layout_height="22dp"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp"
                android:background="@drawable/wave_bar" />

            <View
                android:id="@+id/bar3"
                android:layout_width="5dp"
                android:layout_height="36dp"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp"
                android:background="@drawable/wave_bar" />

            <View
                android:id="@+id/bar4"
                android:layout_width="5dp"
                android:layout_height="22dp"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp"
                android:background="@drawable/wave_bar" />

            <View
                android:id="@+id/bar5"
                android:layout_width="5dp"
                android:layout_height="14dp"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp"
                android:background="@drawable/wave_bar" />

        </LinearLayout>

        <!-- Loading label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:alpha="0.7"
            android:letterSpacing="0.06"
            android:text="Loading your music…"
            android:textColor="#6C63FF"
            android:textSize="12sp" />

        <!-- Branding -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:alpha="0.5"
            android:letterSpacing="0.06"
            android:text="Powered by SKD"
            android:textColor="@color/white"
            android:textSize="11sp" />

    </LinearLayout>

</RelativeLayout>
